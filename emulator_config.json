{
    "pixel_outline": 0,
    "pixel_size": 14,
    "pixel_style": "real",
    "pixel_glow": 6,
    "display_adapter": "browser",
    "allow_adapter_fallback": true,
    "suppress_font_warnings": true,
    "emulator_title": "FlightTracker — live preview",
    "browser": {
        "_comment": "pixel_style 'real' mimics the physical LED panel; use 'square' for the exact 1:1 logical pixel grid.",
        "port": 8888,
        "target_fps": 30,
        "fps_display": false,
        "quality": 80,
        "image_border": false,
        "debug_text": false,
        "image_format": "JPEG",
        "open_immediately": false
    },
    "log_level": "info"
}
